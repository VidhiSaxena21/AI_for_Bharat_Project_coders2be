# Your Database Connection String (Update this when moving to AWS RDS)
DATABASE_URL=postgresql://localhost:5432/foodscanner

# AWS IAM Credentials (requires S3 and Bedrock access)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# AWS Region (e.g., us-east-1, us-west-2, ap-south-1)
AWS_REGION=us-east-1

# Your AWS S3 Bucket Name
S3_BUCKET_NAME=your-app-bucket-name
